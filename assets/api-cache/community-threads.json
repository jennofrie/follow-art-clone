,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":101,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"\u0022Love Is the Key\u0022 \ud83c\udf3b By Joel Equagoo \ud83c\udf37","message":"\u003Ch1\u003EAll We Need is LOVE\u003C\/h1\u003E\u003Cp\u003E\u003C\/p\u003E","image":{"id":15894,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/gaByb30jKeq_8U0o.png"},"messageId":213,"datetime":"2026-03-05 21:17:36","formattedDatetime":"5 Mar 9:17 PM","editDatetime":"2026-03-05 23:22:35","formattedEditDatetime":"5 Mar 11:22 PM","replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":100,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"\u0022Dialogue\u0022 By Jo\u00ebl Equagoo\ud83c\udde8\ud83c\udded","message":"\u003Ch3\u003E\u0022Dialogue\u0022 - new sculpture of Jo\u00ebl Equagoo, Switzerland\ud83c\udde8\ud83c\udded\u003C\/h3\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u0022Dialogue\u0022\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u0022 This sculpture \u0022Dialogue\u0022 by Jo\u00ebl Equagoo symbolizes a dialogue between human beings, which is the basis for a healthy and constructive coexistence between human beings. And therefore supporting constructive ways of communication among humans in all areas of life on our beautiful planet Earth\u0022. Jo\u00ebl Equagoo\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u2705 Dive into the details here \u2026Learn more \u2192 https:\/\/lnkd.in\/eb2t5m2w \ud83c\udde8\ud83c\udded\u003C\/p\u003E","image":{"id":15893,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/3bh4SOKNomMHyw23.JPG"},"messageId":212,"datetime":"2026-03-05 20:39:33","formattedDatetime":"5 Mar 8:39 PM","editDatetime":"2026-03-09 03:31:56","formattedEditDatetime":"9 Mar 3:31 AM","replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":99,"user":{"id":4256,"firstName":"Olha","lastName":"Bublyk","useAlias":false,"alias":null,"slug":"olha-bublyk","type":{"id":"artist","label":"Artist"},"avatar":{"id":13242,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/KcOPXROI6-eW1hnU.png"}},"title":"Nude","message":"\u003Cp\u003EI  just joined and I\u2019m happy to be part of this platform, and would like to share my nude work created using the paint for fabric.\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E","image":{"id":15847,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/AuAB3btldjxpxc-U.jpeg"},"messageId":209,"datetime":"2026-03-04 16:17:41","formattedDatetime":"4 Mar 4:17 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":98,"user":{"id":3725,"firstName":"Melanie","lastName":"Winning","useAlias":false,"alias":null,"slug":"melanie-winning","type":{"id":"artist","label":"Artist"},"avatar":{"id":10523,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Mvw9U3GzIXjfTyAw.png"}},"title":"Masking","message":"\u003Cp\u003EMasking, we humans are good at that.. I am loving my oil on canvas  masks of the world series. \u003C\/p\u003E","image":{"id":15727,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/P2jc1kVi1Ksyq_Tu.jpg"},"messageId":208,"datetime":"2026-03-01 18:59:45","formattedDatetime":"1 Mar 6:59 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":1,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":3,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":96,"user":{"id":4973,"firstName":"Leigh","lastName":"Witherell","useAlias":false,"alias":null,"slug":"leigh-witherell","type":{"id":"artist","label":"Artist"},"avatar":{"id":15040,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/vJCkDzL4LCwsAhSn.png"}},"title":"Does anyone else do a piece over to see progress","message":"\u003Cp\u003ESo I have started working on re-doing this piece. I\u0027ve tightened the composition and chosen some different hues. I think it\u0027s important to check your skill development from time to time and this is a good way to do it. This piece is my husbands favorite, so he\u0027s excited to see it becoming a new painting.  A very wonderful photographer in Melbourne FL took this photo. His name is Kenneth Castro\u003C\/p\u003E","image":{"id":15539,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/V_iTTlkCkBfzk1Mp.jpg"},"messageId":206,"datetime":"2026-02-23 18:02:19","formattedDatetime":"23 Feb 6:02 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":1,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":4,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":95,"user":{"id":297,"firstName":"Samantha","lastName":"Lance","useAlias":false,"alias":null,"slug":"samantha-lance","type":{"id":"curator","label":"Curator"},"avatar":{"id":369,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/68473ae218910_image.png"}},"title":"Exhibition Feature - \u0022We Have The Cure\u0022","message":"\u003Cp\u003EHey all! It\u2019s wonderful to be part of a platform where artists, curators, and arts workers can be connected across the world \ud83c\udf0e \u0026nbsp;\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EI\u2019m Samantha, a Canadian curator and writer \ud83c\udde8\ud83c\udde6 I\u2019m also the Curator at the Visual Arts Centre of Clarington, a non-profit public gallery and education centre based in Bowmanville, Ontario, Canada.\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EI\u2019m excited to share with you our current exhibition, \u201cWe Have The Cure\u201d featuring Kosisochukwu Nnebe, a neurodivergent Nigerian-Canadian artist and researcher.\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EFor generations, cassava has been pulled from the earth by women who understood its dual nature\u2014food and poison, sustenance and sabotage. Records tell us that some enslaved Black women hid traces of the root beneath their fingernails, carrying a quiet insurgency in the smallest crease of the body. Their hands became thresholds between survival and refusal, protection and empowerment.\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EIn \u201cWe Have The Cure\u201d, Nnebe extends this lineage of Black feminist innovation into the present. Working across textiles, video, and installation, she brings together storytelling, historical reflection, and political activism. Her materials\u2014cassava, indigo, fabric\u2014evoke interconnected histories of resistance, healing, and survival. \u201cWe Have The Cure\u201d honours these histories and asks what remains at our fingertips today: how women continue to make, resist, and reimagine in a world structured against their flourishing.\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EIf you would like to read more and check out documentation photos: \u003Cu\u003Ehttps:\/\/www.vac.ca\/2026\/wehavethecure \ud83d\udc85\ud83c\udfff\u003C\/u\u003E\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EYou can also follow us on instagram @visualartscentre and myself @samantha.lance1\u003C\/p\u003E\u003Cp\u003E\u0026nbsp;\u003C\/p\u003E\u003Cp\u003EI hope this exhibition resonates with you and I would be happy to hear your thoughts, questions, and reflections \ud83d\udca1\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E-Installation view of \u0022We Have The Cure\u0022 in the loft gallery at the Visual Arts Centre of Clarington, 2026. Photo: LF Documentation.\u003C\/p\u003E","image":{"id":15457,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/SMIS9QBnrhxq8huF.png"},"messageId":205,"datetime":"2026-02-20 22:58:04","formattedDatetime":"20 Feb 10:58 PM","editDatetime":"2026-02-21 15:43:39","formattedEditDatetime":"21 Feb 3:43 PM","replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":5,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":94,"user":{"id":63,"firstName":"HUIMING","lastName":"NIU","useAlias":false,"alias":null,"slug":"huiming-niu","type":{"id":"artist","label":"Artist"},"avatar":{"id":15360,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/4x4y9_yFD4kPWBb4.png"}},"title":"\u58a8\u97f5\u91d1\u7b26\uff1a\u7a7f\u8d8a\u65f6\u7a7a\u7684\u827a\u672f\u9769\u547d","message":"\u003Cp\u003E\u5728\u591c\u5e55\u4f4e\u5782\u7684\u5c55\u89c8\u5385\u5185\uff0c\u725b\u6167\u660e\u7684\u300a\u9053\u901a\u5929\u5730\u5b81\u9759\u81f4\u8fdc\u300b\u4ee5\u4e00\u79cd\u4e0d\u53ef\u540d\u72b6\u7684\u529b\u91cf\uff0c\u6084\u7136\u4fb5\u5165\u89c2\u8005\u7684\u5fc3\u7075\u9886\u5730\u3002\u8fd9\u5e45\u4f5c\u54c1\uff0c\u5982\u540c\u7a7f\u8d8a\u65f6\u7a7a\u7684\u5916\u6765\u7269\u79cd\uff0c\u5728\u4f20\u7edf\u6c34\u58a8\u7684\u9886\u57df\u91cc\uff0c\u65e2\u7834\u574f\u7740\u65e2\u5b9a\u7684\u79e9\u5e8f\uff0c\u53c8\u4ee5\u72ec\u6709\u7684\u9b45\u529b\u91cd\u6784\u7740\u65b0\u7684\u7f8e\u5b66\u56fe\u666f\u3002\u003C\/p\u003E\u003Cp\u003E\u753b\u9762\u4e0a\uff0c\u591c\u5e55\u4e0b\u7684\u5929\u5730\u5b9b\u5982\u6df7\u6c8c\u521d\u5f00\uff0c\u4e3b\u5cf0\u5dcd\u7136\u5c79\u7acb\u4e8e\u82cd\u832b\u5927\u5730\uff0c\u5e9f\u589f\u4e4b\u4e0b\u5374\u900f\u51fa\u8bd7\u610f\u7684\u5b81\u9759\uff0c\u4e07\u7269\u6697\u85cf\u7eff\u610f\uff0c\u751f\u673a\u52c3\u52c3\u3002\u4e09\u5ea7\u5927\u5c71\uff0c\u6216\u8038\u7acb\uff0c\u6216\u4fef\u5367\uff0c\u5176\u4e2d\u8d34\u6709\u7684\u91d1\u7b26\uff0c\u72b9\u5982\u9547\u5996\u964d\u9b54\u7684\u7b26\u5492\uff0c\u4e0d\u4ec5\u627f\u8f7d\u7740\u753b\u5bb6\u5bf9\u4e16\u95f4\u4e07\u7269\u7684\u5173\u6000\u4e0e\u7948\u613f\uff0c\u66f4\u4f53\u73b0\u4e86\u5176\u6551\u4e16\u6d4e\u6c11\u7684\u4fa0\u5ba2\u7cbe\u795e\u3002\u8fd9\u91d1\u7b26\uff0c\u662f\u753b\u5bb6\u5bf9\u9053\u901a\u5929\u5730\u9886\u609f\u7684\u5916\u5316\uff0c\u4e5f\u662f\u5176\u827a\u672f\u8ffd\u6c42\u7684\u8c61\u5f81\u3002\u003C\/p\u003E\u003Cp\u003E\u725b\u6167\u660e\u4ee5\u52a0\u539a\u719f\u5ba3\u3001\u58a8\u3001\u91d1\u7c89\u3001\u6731\u7802\u3001\u77f3\u9668\u77f3\u3001\u52a8\u7269\u80f6\u7b49\u6750\u6599\uff0c\u7ecf\u8fc7\u4e09\u5341\u591a\u9053\u5de5\u5e8f\uff0c\u53cd\u590d\u63e3\u6469\u6c34\u58a8\u62bd\u8c61\u8bed\u8a00\uff0c\u5c06\u4f20\u7edf\u4e0e\u73b0\u4ee3\u3001\u4e1c\u65b9\u4e0e\u897f\u65b9\u5de7\u5999\u878d\u5408\u3002\u4ed6\u7684\u7ed8\u753b\uff0c\u900f\u8fc7\u6c34\u58a8\u901a\u5f80\u5b87\u5b99\uff0c\u4e58\u7740\u8bd7\u610f\u4ed9\u6e38\u6d2a\u8352\u9053\u573a\uff0c\u6bcf\u4e00\u7b14\uff0c\u6bcf\u4e00\u5212\uff0c\u90fd\u4eff\u4f5b\u662f\u5927\u81ea\u7136\u6700\u672c\u771f\u7684\u547c\u5438\u4e0e\u5f8b\u52a8\u3002\u003C\/p\u003E\u003Cp\u003E\u8fd9\u5e45\u4f5c\u54c1\uff0c\u8ba9\u4eba\u4e0d\u7981\u8054\u60f3\u5230\u88ab\u5f00\u53d1\u67af\u7aed\u7684\u5730\u7403\u7ec8\u4f1a\u8fce\u6765\u4e0d\u53ef\u9006\u8f6c\u7684\u751f\u547d\u8f6e\u56de\u3002\u5728\u8fd9\u7384\u5316\u9e3f\u8499\u7684\u5b87\u5b99\u4e2d\uff0c\u725b\u6167\u660e\u6784\u5efa\u4e86\u81ea\u5df1\u7684\u6c34\u58a8\u79d8\u5883\uff0c\u4ee5\u62bd\u8c61\u7684\u8868\u8fbe\u65b9\u5f0f\uff0c\u8bc9\u8bf4\u7740\u5bf9\u751f\u547d\u3001\u5bf9\u81ea\u7136\u3001\u5bf9\u5b87\u5b99\u7684\u6df1\u523b\u601d\u8003\u3002\u4ed6\u7684\u4f5c\u54c1\uff0c\u4e0d\u4ec5\u662f\u827a\u672f\u7684\u5c55\u73b0\uff0c\u66f4\u662f\u6587\u5316\u7684\u4f20\u627f\u4e0e\u521b\u65b0\uff0c\u662f\u827a\u672f\u5bb6\u793e\u4f1a\u8d23\u4efb\u611f\u4e0e\u5b66\u672f\u4f7f\u547d\u611f\u7684\u4f53\u73b0\u3002\u003C\/p\u003E\u003Cp\u003E\u6c34\u58a8\u827a\u672f\u7684\u73b0\u4ee3\u53d8\u9769\uff0c\u4e0d\u4ec5\u662f\u827a\u672f\u5f62\u6001\u5b66\u610f\u4e49\u4e0a\u7684\u53d8\u5316\uff0c\u66f4\u662f\u73b0\u4ee3\u6587\u5316\u7cbe\u795e\u7684\u5168\u9762\u9769\u65b0\u3002\u8fd9\u79cd\u9769\u65b0\uff0c\u4f9d\u8d56\u827a\u672f\u5bb6\u7684\u5f53\u4ee3\u610f\u8bc6\u89c9\u9192\uff0c\u8bed\u8a00\u5b66\u7684\u8f6c\u5411\u662f\u7ed8\u753b\u8bed\u8a00\u7684\u91cd\u8981\u91cc\u7a0b\u3002\u725b\u6167\u660e\u6b63\u662f\u8fd9\u6837\u4e00\u4f4d\u89c9\u9192\u8005\u3001\u9769\u547d\u8005\uff0c\u4ed6\u81f4\u529b\u4e8e\u505a\u827a\u672f\u5f62\u6001\u73b0\u4ee3\u53d8\u9769\u7684\u5148\u950b\uff0c\u4ee5\u81ea\u5df1\u7684\u65b9\u5f0f\uff0c\u8be0\u91ca\u7740\u6c34\u58a8\u827a\u672f\u7684\u65e0\u9650\u53ef\u80fd\u3002\u003C\/p\u003E\u003Cp\u003E\u7ad9\u5728\u8fd9\u6837\u7684\u827a\u672f\u4f5c\u54c1\u524d\uff0c\u6211\u4eec\u4eff\u4f5b\u80fd\u542c\u89c1\u5386\u53f2\u7684\u56de\u58f0\uff0c\u611f\u53d7\u5230\u5b87\u5b99\