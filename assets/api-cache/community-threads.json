{"status":true,"data":{"items":[{"id":16,"user":{"id":null,"firstName":"FOLLOW.ART","lastName":"","useAlias":false,"alias":null,"slug":"followart","type":{"id":"followart","label":"Nexus of Curators and Artists"},"avatar":{"id":null,"url":"https:\/\/follow.art\/images\/pass\/icon.png"}},"title":"","message":"This community grows when you bring people in. Invite a fellow artist or curator to JOIN!","image":null,"messageId":29,"datetime":"2025-09-04 15:18:58","formattedDatetime":"4 Sep 3:18 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":14,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[],"pinned":true},{"id":113,"user":{"id":5466,"firstName":"Vinay","lastName":"Jalla","useAlias":false,"alias":null,"slug":"vinay-jalla","type":{"id":"artist","label":"Artist"},"avatar":{"id":16563,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/OK03PwZhRuSfva1H.png"}},"title":"\ud83d\ude04 Cartoons that made Altrincham smile: My experience at the Easter Art Fair \ud83d\ude04","message":"\u003Cp\u003EIf you had asked me what I expected from the Altrincham Society of Artists Fair, I would have said paintings, prints, good conversation, and maybe a slice of cake. And yes, all of that was there at the Unitarian Church Hall in Altrincham along with a warm, welcoming atmosphere that makes local art fairs so special.\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003EREAD MORE: https:\/\/www.vinayjalla.co.uk\/blog-vinayjalla\/cartoons-that-made-altrincham-smile-my-experience-at-the-art-fair\u003C\/p\u003E","image":{"id":17133,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/Yh4ZiahSzFVR3XSu.jpg"},"messageId":227,"datetime":"2026-04-10 18:20:57","formattedDatetime":"10 Apr 6:20 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":1,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":1,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":true,"collaboratorsList":[{"id":5466,"firstName":"Vinay","lastName":"Jalla","useAlias":false,"alias":null,"slug":"vinay-jalla","type":{"id":"artist","label":"Artist"},"avatar":{"id":16563,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/OK03PwZhRuSfva1H.png"}}]},{"id":112,"user":{"id":4973,"firstName":"Leigh","lastName":"Witherell","useAlias":false,"alias":null,"slug":"leigh-witherell","type":{"id":"artist","label":"Artist"},"avatar":{"id":15040,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/vJCkDzL4LCwsAhSn.png"}},"title":"She\u0027s done and entered","message":"\u003Cp\u003EI have finally finished my latest and she has been officially entered into the Tucson Erotic Arts Festival. Fingers crossed they like her, I have never entered this show before. Nerve wracking!\u003C\/p\u003E","image":{"id":16597,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/cEhAsANdtv4EQmrs.jpg"},"messageId":225,"datetime":"2026-03-26 23:24:42","formattedDatetime":"26 Mar 11:24 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":2,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":111,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"impact-Nature pedagogy workshop.","message":"\u003Cp\u003EJo\u00ebl Equagoo\u003C\/p\u003E\u003Cp\u003ENature pedagogy workshop :\u003C\/p\u003E\u003Cp\u003EFrom the nature to the source of the\u003C\/p\u003E\u003Cp\u003Eidentity ! Inspirations and experiences in\u003C\/p\u003E\u003Cp\u003Eand with nature are the result\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u2705\u0022read more\u0022 \u0026gt;\u0026gt; https:\/\/www.linkedin.com\/feed\/update\/urn:li:ugcPost:7375927014949597184\/\u003C\/p\u003E","image":{"id":16433,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/_pscA1er3J7h3Z3l.png"},"messageId":224,"datetime":"2026-03-21 18:36:07","formattedDatetime":"21 Mar 6:36 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":110,"user":{"id":5106,"firstName":"Maria","lastName":"L\u00e4ms\u00e4","useAlias":false,"alias":null,"slug":"maria-lamsa","type":{"id":"curator","label":"Curator"},"avatar":{"id":15627,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/QzaSW1ZzFx6CsaOf.png"}},"title":"Curators \u0026 artists \u2014 can you share your experience?","message":"\u003Cp\u003EI\u2019m looking to connect with curators, artists, and cultural practitioners who have worked or are experimenting with bringing art beyond traditional institutions into public space and everyday environments.\u003Cbr\u003E\u003C\/p\u003E\u003Cp\u003EEspecially interested in those who:\u003Cbr\u003E\u2013 engage audiences who don\u2019t usually visit museums or galleries\u003Cbr\u003E\u2013 work with participatory or city-based formats\u003Cbr\u003E\u2013 design projects with a clear message or call to action\u003C\/p\u003E\u003Cp\u003E\u003Cbr\u003EI\u2019d love to hear what you\u2019ve tried, what worked (or didn\u2019t).\u003Cbr\u003E\u003C\/p\u003E\u003Cp\u003EI\u2019m currently thinking in the context of Helsinki, where a growing number of residents live \u0022between languages\u0022 . Many work in English, while much of everyday life still requires Finnish, making integration slow and often one-sided. At the same time, Finnish speakers are also adapting to more English-speaking environments.\u003C\/p\u003E\u003Cp\u003EI\u2019m interested in reframing this as a two-way onboarding: not \u0022someone needs to learn the language\u0022 but \u201cwe learn how to interact with each other\u0022.\u003C\/p\u003E\u003Cp\u003EThe idea is to use artistic, participatory formats in urban space to make mutual support visible, normalize imperfect language use, and show multilingualism as a resource.\u003C\/p\u003E\u003Cp\u003EIf this resonates, I\u2019d love to connect, feel free to comment or send me a message\u003C\/p\u003E","image":{"id":16414,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/9Y5i0qdS3o8IKmGL.png"},"messageId":222,"datetime":"2026-03-19 13:01:52","formattedDatetime":"19 Mar 1:01 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":1,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":2,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":true,"collaboratorsList":[{"id":5106,"firstName":"Maria","lastName":"L\u00e4ms\u00e4","useAlias":false,"alias":null,"slug":"maria-lamsa","type":{"id":"curator","label":"Curator"},"avatar":{"id":15627,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/QzaSW1ZzFx6CsaOf.png"}},{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}}]},{"id":109,"user":{"id":4973,"firstName":"Leigh","lastName":"Witherell","useAlias":false,"alias":null,"slug":"leigh-witherell","type":{"id":"artist","label":"Artist"},"avatar":{"id":15040,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/vJCkDzL4LCwsAhSn.png"}},"title":"Very neat!","message":"\u003Cp\u003EIt\u0027s really neat when I see my work from a past show being used to advertise a new call-out. It\u0027s  a nice pick me up.\u003C\/p\u003E","image":{"id":16129,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/yZi_QQtdYmDzb6dw.PNG"},"messageId":221,"datetime":"2026-03-13 20:50:47","formattedDatetime":"13 Mar 8:50 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":2,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":108,"user":{"id":1018,"firstName":"Ksenija","lastName":"Labecka","useAlias":false,"alias":null,"slug":"ksenija-labecka","type":{"id":"artist","label":"Artist"},"avatar":{"id":8926,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/6861841c94881_image.png"}},"title":"Graduate Open Call","message":"\u003Cp\u003EAre you a fine arts or curatorial student graduating this year?\u003Cbr\u003E\u003Cbr\u003ETake this as your sign to apply to the Graduate Support Program by FOLLOW.ART.\u003Cbr\u003E\u003C\/p\u003E\u003Cp\u003EWe are launching this initiative with two open calls \u2014 one for fine arts students and one for BA or MA curatorial students who are graduating this year. The program is designed to support emerging artists and curators as they take their first professional steps in the art world.\u003Cbr\u003E\u003C\/p\u003E\u003Cp\u003ESelected participants will receive a range of exciting opportunities and prizes, developed together with our collaborators, including professional development resources, industry insights, and unique experiences within the contemporary art ecosystem.\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003EThrough collaborations and initiatives like this, we aim to provide emerging professionals with valuable insights to help them build dynamic and sustainable careers in the art world.\u003Cbr\u003E\u003C\/p\u003E\u003Cp\u003EApplications are free of charge and open until April 26, 2026.\u003C\/p\u003E\u003Cp\u003EFind out more about the prizes and how to apply:\u003Cbr\u003EArtists: https:\/\/lnkd.in\/dy6esfnV\u003Cbr\u003ECurators: https:\/\/lnkd.in\/dxsFt6Zi\u003C\/p\u003E","image":{"id":16113,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/ohFwo2JxBDPte9w4.png"},"messageId":220,"datetime":"2026-03-13 13:12:49","formattedDatetime":"13 Mar 1:12 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":2,"likes":0,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":true,"collaboratorsList":[{"id":1018,"firstName":"Ksenija","lastName":"Labecka","useAlias":false,"alias":null,"slug":"ksenija-labecka","type":{"id":"artist","label":"Artist"},"avatar":{"id":8926,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/6861841c94881_image.png"}},{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}}]},{"id":107,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"Sculpture : Identit\u00e9\/\u00c9galit\u00e9    by Jo\u00ebl Equagoo \ud83c\udde8\ud83c\udded","message":"\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003ESculpture \u0022Identit\u00e9 \u00e9gale - l\u00e9gale\u0022  (  Identit\u00e9\/\u00c9galit\u00e9 ) Both, women and men have a tender and sensitive heart. Both are capable of feeling very deeply. Concept, design \u0026amp; sculpture by Jo\u00ebl Equagoo\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Ch5\u003E\u003C\/h5\u003E\u003Cp\u003E\u003C\/p\u003E","image":{"id":15955,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/bOHRubEwG-3RHqQj.jpg"},"messageId":219,"datetime":"2026-03-09 12:15:49","formattedDatetime":"9 Mar 12:15 PM","editDatetime":"2026-03-09 13:00:48","formattedEditDatetime":"9 Mar 1:00 PM","replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":2,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":106,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"Festival Switzerland, Solothurn At Natural History Museum of Solothurn \ud83c\udde8\ud83c\udded","message":"\u003Cp\u003EFestival\u003Cbr\u003ESwitzerland, Solothurn\u003Cbr\u003EAt Natural History Museum of Solothurn \ud83c\udde8\ud83c\udded\u003Cbr\u003E\u003Cbr\u003E\u003Cbr\u003EInternational Museum Day 2025\ud83c\udde8\ud83c\udded\u003Cbr\u003ELand Art Workshop with artist Jo\u00ebl Equagoo\u003Cbr\u003EThe concept \u2014 portable land art creation \u2014 \u00a9 Jo\u00ebl Equagoo\u003Cbr\u003E\u003Cbr\u003EEducational, exciting, unforgettable\u003Cbr\u003EA visit to the Natural History Museum of Solothurn.\u003Cbr\u003E\u003Cbr\u003EExcited to share my involvement in the Professional Nature Pedagogy project at the Natural History Museum of Solothurn, Switzerland \ud83c\udde8\ud83c\udded\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u2705 Dive into the details here : \u0026gt;\u0026gt; https:\/\/lnkd.in\/dgcA_qZS\u003C\/p\u003E","image":{"id":15930,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/TIM7Y6bwct8_vRkp.jpg"},"messageId":218,"datetime":"2026-03-07 19:17:54","formattedDatetime":"7 Mar 7:17 PM","editDatetime":"2026-03-09 03:28:49","formattedEditDatetime":"9 Mar 3:28 AM","replyCount":1,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":1,"likes":2,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":true,"collaboratorsList":[{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}}]},{"id":105,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"How being authentic can serve your audience","message":"\u003Cp\u003EExperience at one of our workshops\u003C\/p\u003E\u003Cp\u003EJo\u00ebl Equagoo\ud83c\udde8\ud83c\udded,\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003EWorkshop Event Jo\u00ebl Equagoo, CH\ud83c\udde8\ud83c\udded\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u003Cstrong\u003ENature pedagogy workshop with Jo\u00ebl Equagoo: \u201eFrom the nature to the source of the identity !\u0022 Inspirations and experiences in and with nature are the result.\u003C\/strong\u003E\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u0022At the beginning he was really uptight and totally unrelaxed. He was trapped in his role of being an adult and entrepreneur. He had a hard time to relax and forget his role as a business person .\u003C\/p\u003E\u003Cp\u003EThrough our authenticity, natural authority and kindness, and love for nature, we were able to help him open up to the present moment in nature, to relax, to allow time to stand still, free of competition, and to indulge in the beauty of the tasks of the workshop, which helped him to let go of stress, and to fully embrace and enjoy the moment of creativity in nature.\u003C\/p\u003E\u003Cp\u003EDuring the workshop and while working on his own piece of art with natural materials, he looked around, searched along the river and then went into the wood, and shortly after came out with a huge piece of drift wood, which he then proceeded to balance on top of his balanced stones in nature.\u003C\/p\u003E\u003Cp\u003EHe was very proud with the result of his completed workshop task, and really satisfied with the outcome and with his achievement. He was very happy and proud that other workshop participants were taking pictures of his work. The beautiful mixture of taking time, having patience, relaxing and having no competition, allowed him to dive into the moment and come up with a satisfying and renewing experience in nature.\u003C\/p\u003E\u003Cp\u003EIt was beautiful and rewarding to see this man, the way he was when he first came to the workshop, and how only 3 hours later spent in nature with a loving guidance he was smiling and...\u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E\u003Cp\u003E\u2705\u0022read more\u0022 \u0026gt;\u0026gt; https:\/\/www.linkedin.com\/feed\/update\/urn:li:ugcPost:7375927014949597184\/\u003C\/p\u003E","image":{"id":15928,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/jPJ64nO1p5Txp4pg.jpg"},"messageId":217,"datetime":"2026-03-07 14:37:50","formattedDatetime":"7 Mar 2:37 PM","editDatetime":"2026-03-09 03:29:39","formattedEditDatetime":"9 Mar 3:29 AM","replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":1,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":true,"collaboratorsList":[{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}}]},{"id":104,"user":{"id":3565,"firstName":"Joel","lastName":"Equagoo","useAlias":false,"alias":null,"slug":"joel-equagoo-1","type":{"id":"curator","label":"Curator"},"avatar":{"id":9698,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/uploads\/Y6j59G0tL3xHJVsL.png"}},"title":"\u0022Flower for you\u0022  \ud83c\udf38 new sculpture by Jo\u00ebl Equagoo, Switzerland\ud83c\udde8\ud83c\udded","message":"\u003Ch1\u003EA Flower for you !\ud83c\udf38\u003C\/h1\u003E\u003Cp\u003E \u003C\/p\u003E\u003Cp\u003E\u003C\/p\u003E","image":{"id":15914,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=1440,fit=scale-down,format=webp,quality=90\/uploads\/R7knZePIu5XFFQ6w.jpg"},"messageId":216,"datetime":"2026-03-06 22:45:18","formattedDatetime":"6 Mar 10:45 PM","editDatetime":null,"formattedEditDatetime":null,"replyCount":0,"isOwner":false,"isCollaborateParticipant":false,"collaborationParticipants":0,"likes":1,"isLiked":false,"isThreadMessage":true,"inviteToCollaboration":false,"collaboratorsList":[]},{"id":103,"user":{"id":3439,"firstName":"Austra Hel\u0113na","lastName":"\u017daggere","useAlias":false,"alias":null,"slug":"austra-helena-zaggere","type":{"id":"artist","label":"Artist"},"avatar":{"id":10538,"url":"https:\/\/follow.art\/cdn-cgi\/image\/width=320,height=320,fit=cover,format=webp,quality=90\/u